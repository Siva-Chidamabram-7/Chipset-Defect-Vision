# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.pytest_cache/
*.log

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
.env

# ── Dataset files ─────────────────────────────────────────────────────────────
# Ignore actual image and label files (large, machine-local).
# We ignore by EXTENSION so that .gitkeep placeholder files are still tracked —
# preserving the directory scaffold in git without committing dataset content.

# Generated YOLO dataset — new location (training/data/)
training/data/images/**/*.jpg
training/data/images/**/*.jpeg
training/data/images/**/*.png
training/data/images/**/*.bmp
training/data/images/**/*.webp
training/data/labels/**/*.txt
training/data/**/*.cache

# Generated YOLO dataset — legacy location (data/ at project root)
data/images/**/*.jpg
data/images/**/*.jpeg
data/images/**/*.png
data/images/**/*.bmp
data/images/**/*.webp
data/labels/**/*.txt
data/**/*.cache

# Raw source images (raw_data/ — class-labelled subdirectories)
raw_data/**/*.jpg
raw_data/**/*.jpeg
raw_data/**/*.png
raw_data/**/*.bmp
raw_data/**/*.webp
raw_data/**/*.tiff
raw_data/labels/**/*.txt

# ── Model weights ─────────────────────────────────────────────────────────────
# Trained weights are large binaries — manage outside git.
# For factory deployments, transfer them via USB or shared network drive.
# yolov8n.pt is baked into the Docker image at build time; no need to commit it.
weights/best.pt
weights/last.pt
weights/yolov8n.pt

# ── SAM model weights ─────────────────────────────────────────────────────────
# SAM checkpoints are large (~375 MB – 2.4 GB); manage outside git.
# Transfer to weights/ manually for offline use.
weights/sam_vit_b.pth
weights/sam_vit_l.pth
weights/sam_vit_h.pth

# ── SAM intermediate outputs ──────────────────────────────────────────────────
# Region JSON files (output of generate_regions.py) are machine-local artefacts.
# Ignore the content but keep the directory scaffold via .gitkeep.
raw_data/regions/**/*.json

# ── Training artefacts ────────────────────────────────────────────────────────
runs/
datasets/

# ── YOLO / ultralytics build artefacts ───────────────────────────────────────
# yolov8n.pt sometimes lands in the project root when scripts run from there.
yolov8n.pt
*.pt
# ultralytics auto-generated label cache (binary, machine-local)
data/labels.cache
data/**/*.cache

# ── Tooling binaries in project root ─────────────────────────────────────────
# gh CLI binary (accidentally placed in repo root)
/gh

# ── OS artefacts ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
