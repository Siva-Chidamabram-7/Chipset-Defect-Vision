# ── Inference ─────────────────────────────────────────────────────────────────
INFERENCE_CONFIDENCE_THRESHOLD=0.25
MAX_IMAGE_BYTES=10485760

# ── GCP / Vertex AI ───────────────────────────────────────────────────────────
GCP_PROJECT_ID=chip-defect-identification
GCP_REGION=asia-south1

# ── GCS paths — set these before running training or vertex_job.py ─────────────
GCS_DATA_URI=gs://your-bucket/data/
GCS_MODEL_OUTPUT_URI=gs://your-bucket/models/
VERTEX_STAGING_BUCKET=gs://your-bucket/staging/

# Training container image pushed to Artifact Registry (required for Vertex AI)
VERTEX_TRAIN_IMAGE_URI=asia-south1-docker.pkg.dev/chip-defect-identification/chipset-defect/training:latest

# ── Vertex AI machine config (optional — override defaults) ───────────────────
VERTEX_ACCELERATOR_TYPE=NVIDIA_TESLA_T4
VERTEX_ACCELERATOR_COUNT=1
VERTEX_MACHINE_TYPE=n1-standard-8

# ── Training hyperparameters (optional — override defaults) ───────────────────
TRAIN_EPOCHS=50
TRAIN_BATCH_SIZE=16
TRAIN_LEARNING_RATE=0.001
TRAIN_IMAGE_SIZE=640
TRAIN_OPTIMIZER=AdamW
TRAIN_DEVICE=cuda
TRAIN_PATIENCE=20
TRAIN_RUN_NAME=pcb_solder_v1

# ── Auth (local dev only) ─────────────────────────────────────────────────────
# On Cloud Run / Vertex AI use Workload Identity instead of a key file.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
