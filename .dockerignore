# ─────────────────────────────────────────────────────────────────────────────
# .dockerignore — Inference image build context
#
# Strategy: EXCLUDE EVERYTHING — then allow only what the running container
# actually needs.
#
#   INCLUDED (inference runtime):
#     app/              FastAPI application + model loader
#     frontend/         Static glassmorphic UI (HTML / CSS / JS)
#     weights/best.pt   Fine-tuned 7-class PCB defect model  ← ONLY this file
#     requirements.txt  Pinned inference dependencies
#
#   EXCLUDED (everything else):
#     Training code, SAM scripts, datasets, runs, docs, dev tools, OS noise
#
# Keeping the build context small:
#   • Speeds up  docker build  (no multi-hundred-MB data transfer to daemon)
#   • Prevents accidental inclusion of dataset images, model checkpoints,
#     SAM weights, or secrets
# ─────────────────────────────────────────────────────────────────────────────


# ── Default: exclude everything ───────────────────────────────────────────────
**

# ── Re-include: inference application ─────────────────────────────────────────
!app/
!app/**
!frontend/
!frontend/**
!requirements.txt

# ── Re-include: ONLY the trained inference model ───────────────────────────────
# weights/ is excluded by default above; we punch through exactly one file.
!weights/
!weights/best.pt


# ─────────────────────────────────────────────────────────────────────────────
# EXPLICIT EXCLUSIONS — belt-and-suspenders on top of the default-deny above.
# These are listed so intent is obvious to future readers even if the default-
# deny pattern is ever modified.
# ─────────────────────────────────────────────────────────────────────────────

# ── Version control ───────────────────────────────────────────────────────────
.git
.gitignore
.gitattributes

# ── Training pipeline (code + configs) ────────────────────────────────────────
training/
[!]training/
scripts/
Dockerfile.training

# ── Training-only dependency files ────────────────────────────────────────────
requirements-sam.txt
requirements-training.txt

# ── Dataset directories (can be gigabytes) ────────────────────────────────────
data/
raw_data/
datasets/

# ── Training run artifacts ─────────────────────────────────────────────────────
runs/

# ── All weights EXCEPT best.pt ────────────────────────────────────────────────
weights/last.pt
weights/yolov8n.pt
weights/*.pth

# ── Root-level stray binaries ─────────────────────────────────────────────────
yolov8n.pt
gh

# ── Python artifacts ──────────────────────────────────────────────────────────
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.pytest_cache/
*.log

# ── Local virtual environments ────────────────────────────────────────────────
.venv/
venv/
env/

# ── Secrets ───────────────────────────────────────────────────────────────────
.env
*.env

# ── Documentation (not needed at runtime) ─────────────────────────────────────
README.md
CHANGELOG.md
docs/

# ── OS artefacts ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── IDE / editor config ───────────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ── Node (not used — safety net) ──────────────────────────────────────────────
node_modules/

# ── Runtime-generated directories (created at startup, not at build time) ─────
incoming_data/
