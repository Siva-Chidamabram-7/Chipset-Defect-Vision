# ─────────────────────────────────────────────────────────────────────────────
# .dockerignore — Inference image build context filter
#
# Rule: only include what the RUNNING CONTAINER needs.
#   Included → app/  frontend/  weights/  requirements.txt
#   Excluded → everything else (training code, datasets, dev tools, OS noise)
#
# Keeping the build context small speeds up `docker build` and prevents
# accidental inclusion of large dataset files or secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Version control ───────────────────────────────────────────────────────────
.git
.gitignore
.gitattributes

# ── Python artefacts ──────────────────────────────────────────────────────────
__pycache__
**/__pycache__
*.pyc
*.pyo
*.pyd
*.egg-info
.pytest_cache
*.log

# ── Local virtual environments & secrets ──────────────────────────────────────
.venv
venv
env
.env
*.env

# ── ML training code (local only — never runs inside the container) ───────────
training/

# ── Dataset-creation scripts (SAM + annotation tools — GUI + heavy deps) ──────
scripts/

# ── Dataset directories (can be gigabytes — not needed for inference) ─────────
data/
raw_data/
datasets/
runs/

# ── SAM / dev-only Python dependencies ────────────────────────────────────────
requirements-sam.txt

# ── Documentation ─────────────────────────────────────────────────────────────
README.md
CHANGELOG.md
docs/

# ── OS artefacts ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── IDE / editor config ───────────────────────────────────────────────────────
.vscode
.idea
*.sublime-project
*.sublime-workspace

# ── Node (not used — safety net) ──────────────────────────────────────────────
node_modules
